DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=Bimbingan_Online
DB_PORT=3306

JWT_SECRET=your_jwt_secret_key_here_change_in_production_min_16_chars
JWT_EXPIRES_IN=7d

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars_change_in_production
BETTER_AUTH_URL=http://localhost:3000

# Upstash Redis (get from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

PORT=3000
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Google Drive Configuration
# Google Drive Folder IDs (create folders in Drive and copy their IDs)
GDRIVE_FOLDER_PROPOSALS=your_proposals_folder_id
GDRIVE_FOLDER_REPORTS=your_reports_folder_id
GDRIVE_FOLDER_PROFILES=your_profiles_folder_id
GDRIVE_FOLDER_BIMBINGAN=your_bimbingan_folder_id
GDRIVE_FOLDER_DEFAULT=your_default_folder_id

ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=change_this_to_a_secure_password

# Mailtrap (OTP Email)
MAILTRAP_API_TOKEN=your_mailtrap_api_token_here

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=kavanahub-api